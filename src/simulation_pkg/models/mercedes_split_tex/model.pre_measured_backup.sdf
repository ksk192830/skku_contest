<?xml version="1.0"?>
<sdf version="1.7">
  <model name="mercedes_split_tex">
    <static>false</static>

    <!-- Chassis -->
    <link name="chassis">
      <pose>0 0 0 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>800</mass>
        <inertia>
          <ixx>300</ixx><iyy>900</iyy><izz>1000</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="body_visual">
        <!-- OBJ authored in Y-up; rotate to Gazebo Z-up + forward X -->
        <pose>0 0 0 1.5708 0 1.5708</pose>
        <geometry>
          <mesh>
            <uri>model://mercedes_split_tex/meshes/body.obj</uri>
            <scale>100 100 100</scale>
          </mesh>
        </geometry>
        <cast_shadows>false</cast_shadows>
      </visual>

      <collision name="chassis_collision">
        <pose>-0.05 0 0.76 0 0 0</pose>
        <geometry>
          <box><size>4.7 2.0 1.2</size></box>
        </geometry>
      </collision>
    </link>

    <!-- Front steering knuckles -->
    <link name="front_left_steer">
      <pose>1.5144 0.8183 0.3572 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
    </link>

    <link name="front_right_steer">
      <pose>1.5144 -0.8185 0.3572 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
    </link>

    <!-- Wheels -->
    <link name="front_left_wheel">
      <pose>1.5144 0.8183 0.3572 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>20</mass>
        <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="wheel_fl_visual">
        <pose>-1.5144 -0.8183 -0.3572 1.5708 0 1.5708</pose>
        <geometry>
          <mesh>
            <uri>model://mercedes_split_tex/meshes/wheel_fl.obj</uri>
            <scale>100 100 100</scale>
          </mesh>
        </geometry>
        <cast_shadows>false</cast_shadows>
      </visual>
      <collision name="wheel_fl_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.355</radius><length>0.28</length></cylinder></geometry>
      </collision>
    </link>

    <link name="front_right_wheel">
      <pose>1.5144 -0.8185 0.3572 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>20</mass>
        <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="wheel_fr_visual">
        <pose>-1.5144 0.8185 -0.3572 1.5708 0 1.5708</pose>
        <geometry>
          <mesh>
            <uri>model://mercedes_split_tex/meshes/wheel_fr.obj</uri>
            <scale>100 100 100</scale>
          </mesh>
        </geometry>
        <cast_shadows>false</cast_shadows>
      </visual>
      <collision name="wheel_fr_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.355</radius><length>0.28</length></cylinder></geometry>
      </collision>
    </link>

    <link name="rear_left_wheel">
      <pose>-1.4000 0.8023 0.3564 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>20</mass>
        <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="wheel_rl_visual">
        <pose>1.4000 -0.8023 -0.3564 1.5708 0 1.5708</pose>
        <geometry>
          <mesh>
            <uri>model://mercedes_split_tex/meshes/wheel_rl.obj</uri>
            <scale>100 100 100</scale>
          </mesh>
        </geometry>
        <cast_shadows>false</cast_shadows>
      </visual>
      <collision name="wheel_rl_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.355</radius><length>0.28</length></cylinder></geometry>
      </collision>
    </link>

    <link name="rear_right_wheel">
      <pose>-1.4000 -0.8027 0.3564 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>20</mass>
        <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="wheel_rr_visual">
        <pose>1.4000 0.8027 -0.3564 1.5708 0 1.5708</pose>
        <geometry>
          <mesh>
            <uri>model://mercedes_split_tex/meshes/wheel_rr.obj</uri>
            <scale>100 100 100</scale>
          </mesh>
        </geometry>
        <cast_shadows>false</cast_shadows>
      </visual>
      <collision name="wheel_rr_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.355</radius><length>0.28</length></cylinder></geometry>
      </collision>
    </link>

    <!-- Steering joints (front) -->
    <joint name="front_left_steer_joint" type="revolute">
      <parent>chassis</parent>
      <child>front_left_steer</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower><upper>0.6</upper>
          <effort>80</effort><velocity>10</velocity>
        </limit>
        <dynamics><damping>2.0</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <joint name="front_right_steer_joint" type="revolute">
      <parent>chassis</parent>
      <child>front_right_steer</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower><upper>0.6</upper>
          <effort>80</effort><velocity>10</velocity>
        </limit>
        <dynamics><damping>2.0</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <!-- Wheel spin joints -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>front_left_steer</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower><upper>1e16</upper>
          <effort>200</effort><velocity>100</velocity>
        </limit>
        <dynamics><damping>1.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="front_right_wheel_joint" type="revolute">
      <parent>front_right_steer</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower><upper>1e16</upper>
          <effort>200</effort><velocity>100</velocity>
        </limit>
        <dynamics><damping>1.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower><upper>1e16</upper>
          <effort>200</effort><velocity>100</velocity>
        </limit>
        <dynamics><damping>1.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower><upper>1e16</upper>
          <effort>200</effort><velocity>100</velocity>
        </limit>
        <dynamics><damping>1.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <plugin name="ackermann" filename="libgazebo_ros_ackermann_drive.so">
      <chassis>chassis</chassis>
      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <rear_left_joint>rear_left_wheel_joint</rear_left_joint>
      <rear_right_joint>rear_right_wheel_joint</rear_right_joint>
      <left_steering_joint>front_left_steer_joint</left_steering_joint>
      <right_steering_joint>front_right_steer_joint</right_steering_joint>

      <update_rate>60.0</update_rate>
      <left_steering_pid_gain>800 0 3</left_steering_pid_gain>
      <left_steering_i_range>0 0</left_steering_i_range>
      <right_steering_pid_gain>800 0 3</right_steering_pid_gain>
      <right_steering_i_range>0 0</right_steering_i_range>
      <linear_velocity_pid_gain>500 0 2</linear_velocity_pid_gain>
      <linear_velocity_i_range>0 0</linear_velocity_i_range>

      <max_steer>0.55</max_steer>
      <max_steering_angle>7.85</max_steering_angle>
      <max_speed>3.0</max_speed>

      <robot_base_frame>chassis</robot_base_frame>
      <odometry_frame>odom</odometry_frame>
      <publish_odom>0</publish_odom>
      <publish_odom_tf>0</publish_odom_tf>
      <publish_wheel_tf>1</publish_wheel_tf>
      <publish_distance>0</publish_distance>
    </plugin>
  </model>
</sdf>
